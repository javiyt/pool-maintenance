# =============================================================================
# Pool Maintenance -- Environment variables
# =============================================================================
# Copy this file to ~/pool-maintenance/.env on the Raspberry Pi.
#
# Environment variables are loaded by the Quadlet container at runtime.
# =============================================================================

# Host port to map to the container's internal port 80.
# The app always listens on port 80 inside the container; this env var controls
# the external port on the Raspberry Pi (via PublishPort in the Quadlet).
# Default: 8090
# POOL_MAINTENANCE_PORT=8090
